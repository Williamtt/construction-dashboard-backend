// Construction Dashboard - 多專案、人員；預留租戶
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- 租戶（多租戶時使用；單租戶可僅一筆或固定 id）----------
model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String?   @unique
  status    String    @default("active") // active | suspended
  expiresAt DateTime? @map("expires_at")
  userLimit Int?      @map("user_limit")       // 人員上限（未來）
  fileSizeLimitMb Int? @map("file_size_limit_mb") // 單筆上傳 MB（未來）
  storageQuotaMb  Int? @map("storage_quota_mb")   // 總儲存 MB（未來）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  projects Project[]
}

// ---------- 人員（使用者）----------
enum SystemRole {
  platform_admin  // 平台管理員（多租後台）
  tenant_admin    // 租戶／公司管理員（單租後台）
  project_user    // 專案層使用者
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String?
  systemRole   SystemRole @default(project_user) @map("system_role")
  memberType   String     @default("internal") @map("member_type") // internal | external
  tenantId     String?    @map("tenant_id")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant        Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  projectMembers ProjectMember[]
}

// ---------- 專案 ----------
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String?  // 專案代碼
  status      String   @default("active") // active | archived
  tenantId    String?  @map("tenant_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 專案資訊（契約／工程基本資料）
  designUnit     String?   @map("design_unit")      // 設計單位
  supervisionUnit String?  @map("supervision_unit")  // 監造單位
  contractor     String?  @map("contractor")        // 施工廠商
  summary        String?  @map("summary")          // 工程概要
  benefits       String?  @map("benefits")          // 工程效益
  startDate      DateTime? @map("start_date")       // 開工日期
  plannedEndDate DateTime? @map("planned_end_date")  // 預定完工日期（原訂）
  revisedEndDate  DateTime? @map("revised_end_date") // 變更竣工日期（依工期調整後；未變更則 null）
  siteManager    String?  @map("site_manager")      // 工地負責人
  contactPhone   String?  @map("contact_phone")    // 聯絡電話
  projectStaff   String?  @map("project_staff")    // 專案工程人員

  tenant              Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  projectMembers      ProjectMember[]
  scheduleAdjustments ProjectScheduleAdjustment[]
}

// ---------- 工期調整（專案內展延／停工申請與核定）----------
model ProjectScheduleAdjustment {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  applyDate    DateTime @map("apply_date")   // 申請日期
  type         String   @map("type")         // extension | suspension | other
  applyDays    Int      @map("apply_days")   // 申請天數
  approvedDays Int      @map("approved_days") // 核定天數
  status       String   @map("status")       // pending | approved | rejected
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_schedule_adjustments")
}

// ---------- 專案成員（使用者－專案－角色）----------
enum ProjectRole {
  project_admin  // 專案管理員
  member         // 一般成員
  viewer         // 唯讀
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String     @map("project_id")
  userId    String     @map("user_id")
  role      ProjectRole @default(member)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}
